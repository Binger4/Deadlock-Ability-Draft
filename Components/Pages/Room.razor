    private RenderFragment AbilityTile(AbilityDefinition ability, DraftAbilityPoolItem? poolItem, bool hideIdentity = false) => builder =>
    {
        var picked = CurrentRoom?.PickedAbilityKeys.Contains(ability.Key) == true;
        var canPick = CurrentRoom is not null && RoomService.CanPlayerPickKey(CurrentRoom, PlayerId, ability.Key);
        var displayName = hideIdentity ? "Hidden ability" : ability.DisplayName;
        var icon = hideIdentity ? "/icons/hidden-icon.png" : ability.IconDataUrl;
        var title = hideIdentity
            ? "Hidden ability"
            : poolItem?.IsReplacement == true
                ? $"{ability.DisplayName} | {ability.Key} | Replacement: {poolItem.ReplacementReason} | Source: {ability.SourceHeroName}"
                : $"{ability.DisplayName} | {ability.Key} | {ability.SourceHeroName} {ability.SourceSlot}";
        var sequence = 0;
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "class", $"ability-tile grouped{(picked ? " picked" : string.Empty)}{(poolItem?.IsReplacement == true ? " replacement" : string.Empty)}{(ability.PickKind == DraftPickKind.UltimateAbility ? " ultimate" : string.Empty)}{(hideIdentity ? " blind-hidden" : string.Empty)}");
        builder.AddAttribute(sequence++, "disabled", !canPick);
        builder.AddAttribute(sequence++, "title", title);
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => Pick(ability.Key)));
        builder.AddAttribute(sequence++, "oncontextmenu", EventCallback.Factory.Create<MouseEventArgs>(this, args => OpenDraftItemMenu(args, ability.Key, displayName, hideIdentity)));
        builder.AddEventPreventDefaultAttribute(sequence++, "oncontextmenu", true);
        if (!string.IsNullOrWhiteSpace(icon))
        {
            builder.OpenElement(sequence++, "img");
            builder.AddAttribute(sequence++, "src", icon);
            builder.AddAttribute(sequence++, "alt", displayName);
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "icon-placeholder");
            builder.AddContent(sequence++, Initials(displayName));
            builder.CloseElement();
        }
        if (picked)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "picked-cross");
            builder.AddAttribute(sequence++, "aria-hidden", "true");
            builder.AddContent(sequence++, "X");
            builder.CloseElement();
        }
        builder.OpenElement(sequence++, "small");
        builder.AddContent(sequence++, displayName);
        builder.CloseElement();
        builder.CloseElement();
    };

