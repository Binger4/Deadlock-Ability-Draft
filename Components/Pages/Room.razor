    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "?";
        }

        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private void OnRoomChanged(string roomCode)
    {
        if (!string.Equals(roomCode, Code, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            RoomNotice = RoomService.GetNotice(Code, PlayerId) ?? string.Empty;
            CurrentRoom = RoomService.GetRoom(Code);
            StateHasChanged();
        });
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        if (!IsCurrentRoomUri(args.Location))
        {
            DisconnectLocalSession();
        }
    }

    private bool IsCurrentRoomUri(string uri)
    {
        var relative = Nav.ToBaseRelativePath(uri).Split('?', '#')[0].Trim('/');
        return relative.Equals($"room/{Code}/lobby", StringComparison.OrdinalIgnoreCase) ||
               relative.Equals($"room/{Code}/draft", StringComparison.OrdinalIgnoreCase);
    }

    private void DisconnectLocalSession()
    {
        if (!PresenceRegistered ||
            LocalDisconnectReported ||
            SuppressDisconnectOnDispose ||
            string.IsNullOrWhiteSpace(PlayerId))
        {
            return;
        }

        LocalDisconnectReported = true;
        RoomService.MarkPlayerDisconnected(Code, PlayerId);
    }

    public void Dispose()
    {
        RoomService.RoomChanged -= OnRoomChanged;
        Nav.LocationChanged -= OnLocationChanged;
        DisconnectLocalSession();
    }

