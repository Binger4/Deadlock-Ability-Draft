    private void ToggleMutedPlayer()
    {
        var playerId = ActiveContextMenu?.PlayerId;
        if (string.IsNullOrWhiteSpace(playerId))
        {
            CloseContextMenu();
            return;
        }

        if (!MutedPlayerIds.Add(playerId))
        {
            MutedPlayerIds.Remove(playerId);
        }

        CloseContextMenu();
    }

    private bool IsMuted(string? playerId) =>
        !string.IsNullOrWhiteSpace(playerId) && MutedPlayerIds.Contains(playerId);

    private void CloseContextMenu() => ActiveContextMenu = null;

