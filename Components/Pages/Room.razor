    private static uint StableBlindOrder(string roomCode, string abilityKey)
    {
        unchecked
        {
            var hash = 2166136261u;
            foreach (var character in $"{roomCode}:{abilityKey}")
            {
                hash ^= character;
                hash *= 16777619u;
            }

            return hash;
        }
    }

