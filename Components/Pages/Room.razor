                    <button @onclick="SendChat">Send</button>
                </div>
            }
        }
    </section>;

    private RenderFragment ContextMenuPanel() => @<div>
        <button class="context-menu-backdrop" @onclick="CloseContextMenu" aria-label="Close menu"></button>
        <div class="context-menu" style="@($"left:{ActiveContextMenu!.X}px; top:{ActiveContextMenu.Y}px")">
            @if (ActiveContextMenu.Kind == RoomContextMenuKind.Player)
            {
                <button @onclick="ToggleMutedPlayer">@(IsMuted(ActiveContextMenu.PlayerId) ? "Unmute" : "Mute")</button>
            }
            else if (!CurrentRoom!.Config.DisableChat)
            {
                <button @onclick="() => SendQuickChat(DraftQuickChatAction.WantThis)">Want this</button>
                <button @onclick="() => SendQuickChat(DraftQuickChatAction.Recommend)">Recommend</button>
            }
        </div>
    </div>;

    private IEnumerable<DraftChatMessage> VisibleChatMessages()
    {
        if (CurrentRoom is null || CurrentRoom.Config.DisableChat)
        {
            return [];
        }

        return CurrentRoom.ChatMessages
            .Where(message => !IsMuted(message.SenderPlayerId))
            .Where(message => message.Scope == DraftChatScope.All ||
                              (CurrentClient is not null && message.SenderTeam == CurrentClient.Team))
            .TakeLast(80);
    }

    private static string ChatScopeLabel(DraftChatScope scope) =>
        scope == DraftChatScope.All ? "all" : "allies";

    private void ToggleChatScope() =>
        ChatScope = ChatScope == DraftChatScope.Allies ? DraftChatScope.All : DraftChatScope.Allies;

    private void ToggleChatCollapsed() => ChatCollapsed = !ChatCollapsed;

    private void SendChat()
    {
        var text = ChatText;
        try
        {
            ClearMessage();
            RoomService.SendChatMessage(Code, PlayerId ?? string.Empty, ChatScope, text);
            ChatText = string.Empty;
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message);
        }
    }

    private void HandleChatKey(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
