    private void Try(Action action)
    {
        try
        {
            ClearMessage();
            action();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message);
        }
    }

    private void SetMessage(string value, bool autoClear = true)
    {
        Message = value;
        var version = ++MessageVersion;
        if (autoClear)
        {
            _ = ClearMessageAfterDelay(version);
        }
    }

    private void ClearMessage()
    {
        Message = string.Empty;
        MessageVersion++;
    }

    private void SetCopyMessage(string value)
    {
        CopyMessage = value;
        _ = ClearCopyMessageAfterDelay(++CopyMessageVersion);
    }

    private void SetPresetMessage(string value)
    {
        PresetMessage = value;
        _ = ClearPresetMessageAfterDelay(++PresetMessageVersion);
    }

    private async Task ClearMessageAfterDelay(int version)
    {
        try
        {
            await Task.Delay(TransientMessageDuration);
            if (version != MessageVersion)
            {
                return;
            }

            Message = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private async Task ClearCopyMessageAfterDelay(int version)
    {
        try
        {
            await Task.Delay(TransientMessageDuration);
            if (version != CopyMessageVersion)
            {
                return;
            }

            CopyMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private async Task ClearPresetMessageAfterDelay(int version)
    {
        try
        {
            await Task.Delay(PresetMessageDuration);
            if (version != PresetMessageVersion)
            {
                return;
            }

            PresetMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

