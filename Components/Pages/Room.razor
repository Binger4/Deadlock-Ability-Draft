    private IEnumerable<HeroDefinition> FilteredLobbyHeroes()
    {
        var heroes = CurrentRoom?.DeadlockData.Heroes ?? [];
        return heroes
            .Where(hero => MatchesLobbyCustomSearch(hero.DisplayName, hero.Key))
            .OrderBy(hero => hero.DisplayName);
    }

    private IEnumerable<AbilityDefinition> FilteredLobbyAbilities()
    {
        var abilities = CurrentRoom?.DeadlockData.Abilities ?? [];
        return abilities
            .Where(ability => ability.PickKind is DraftPickKind.RegularAbility or DraftPickKind.UltimateAbility)
            .Where(ability => CurrentRoom is null || !DraftPoolGenerator.IsAbilityAutoBanned(ability, CurrentRoom.DeadlockData))
            .Where(ability => MatchesLobbyCustomSearch(ability.DisplayName, ability.Key, ability.SourceHeroName))
            .OrderBy(ability => ability.DisplayName);
    }

    private bool MatchesLobbyCustomSearch(params string[] values)
    {
        if (string.IsNullOrWhiteSpace(LobbyCustomBanSearch))
        {
            return true;
        }

        return values.Any(value => value.Contains(LobbyCustomBanSearch, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<HeroDraftGroup> DraftHeroBlocks()
    {
        if (CurrentRoom is null)
        {
            yield break;
        }

        if (BlindDraftActive)
        {
            foreach (var block in BlindHeroDraftBlocks())
            {
                yield return block;
            }

            yield break;
        }

        foreach (var heroKey in CurrentRoom.DraftHeroPoolKeys)
        {
            var hero = CurrentRoom.DeadlockData.Heroes.FirstOrDefault(item => item.Key == heroKey);
            if (hero is null)
            {
                continue;
            }

            var entries = hero.DraftableAbilityKeys()
                .Select(MakeEntry)
                .Where(entry => entry is not null)
                .Select(entry => entry!)
                .Where(entry => entry.Ability.PickKind == DraftPickKind.RegularAbility)
                .ToList();

            if (entries.Count > 0)
            {
                yield return new HeroDraftGroup(hero, entries);
            }
        }

        DraftAbilityEntry? MakeEntry(string originalAbilityKey)
        {
            var poolItem = CurrentRoom.DraftAbilityPool.FirstOrDefault(item => item.OriginalAbilityKey == originalAbilityKey || item.AbilityKey == originalAbilityKey);
            if (poolItem is null)
            {
                return null;
            }

            var ability = CurrentRoom.DeadlockData.Abilities.FirstOrDefault(item => item.Key == poolItem.AbilityKey);
            return ability is null ? null : new DraftAbilityEntry(ability, poolItem);
        }
    }

    private IEnumerable<HeroDraftGroup> BlindHeroDraftBlocks()
    {
        if (CurrentRoom is null)
        {
            yield break;
        }

        var heroes = CurrentRoom.DraftHeroPoolKeys
            .Select(key => CurrentRoom.DeadlockData.Heroes.FirstOrDefault(hero => hero.Key == key))
            .Where(hero => hero is not null)
            .Select(hero => hero!)
            .ToList();
        if (heroes.Count == 0)
        {
            yield break;
        }

        var groups = heroes
            .Select(hero => new List<DraftAbilityEntry>())
            .ToList();
        var mixedAbilities = CurrentRoom.DraftAbilityPool
            .OrderBy(item => StableBlindOrder(CurrentRoom.Code, item.AbilityKey))
            .Select(item =>
            {
                var ability = CurrentRoom.DeadlockData.Abilities.FirstOrDefault(ability => ability.Key == item.AbilityKey);
                return ability?.PickKind == DraftPickKind.RegularAbility
                    ? new DraftAbilityEntry(ability, item)
                    : null;
            })
            .Where(entry => entry is not null)
            .Select(entry => entry!)
            .ToList();

        for (var i = 0; i < mixedAbilities.Count; i++)
        {
            groups[i % groups.Count].Add(mixedAbilities[i]);
        }

        for (var i = 0; i < heroes.Count; i++)
        {
            yield return new HeroDraftGroup(heroes[i], groups[i]);
        }
    }

    private IEnumerable<DraftAbilityEntry> UltimateEntries()
    {
        if (CurrentRoom is null)
        {
            yield break;
        }

        foreach (var poolItem in CurrentRoom.DraftAbilityPool)
        {
            var ability = CurrentRoom.DeadlockData.Abilities.FirstOrDefault(item => item.Key == poolItem.AbilityKey);
            if (ability?.PickKind != DraftPickKind.UltimateAbility)
            {
                continue;
            }

            yield return new DraftAbilityEntry(ability, poolItem);
        }
    }

