    private IEnumerable<(int Index, string Label, string? Key, bool IsUltimate)> AbilitySlots(DraftPlayerSlot player)
    {
        if (CurrentRoom?.Config.FlexibleUltimateSlots == true)
        {
            for (var i = 0; i < CurrentRoom.Config.RequiredAbilitySlots; i++)
            {
                yield return (i, (i + 1).ToString(), player.Loadout.RegularAbilities.ElementAtOrDefault(i), false);
            }

            yield break;
        }

        var regularSlots = CurrentRoom?.Config.RegularAbilityPicksPerPlayer ?? 3;
        for (var i = 0; i < regularSlots; i++)
        {
            yield return (i, (i + 1).ToString(), player.Loadout.RegularAbilities.ElementAtOrDefault(i), false);
        }

        if ((CurrentRoom?.Config.UltimatePicksPerPlayer ?? 1) > 0)
        {
            yield return (regularSlots, "U", player.Loadout.Ultimate, true);
        }
    }

    private static string MiniSlotClass(bool hasAbility, bool isUltimate, bool canDrag, bool canDrop, bool isDragging)
    {
        var classes = new List<string>
        {
            "mini-slot",
            hasAbility ? "filled" : "empty",
            isUltimate ? "ultimate" : "normal"
        };

        if (canDrag)
        {
            classes.Add("draggable");
        }

        if (canDrop)
        {
            classes.Add("drop-target");
        }

        if (!canDrag && !canDrop)
        {
            classes.Add("locked");
        }

        if (isDragging)
        {
            classes.Add("dragging");
        }

        return string.Join(' ', classes);
    }

    private bool ShouldHideAbilityIdentity(AbilityDefinition ability) =>
