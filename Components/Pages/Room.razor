        foreach (var entry in block.Abilities)
        {
            AbilityTile(entry.Ability, entry.PoolItem, hideIdentity: ShouldHideAbilityIdentity(entry.Ability))(builder);
        }
        builder.CloseElement();

        builder.CloseElement();
    };

    private RenderFragment PlayerPanel(DraftPlayerSlot player) => builder =>
