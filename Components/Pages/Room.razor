    private async Task GenerateZip()
    {
        if (IsGeneratingFiles)
        {
            return;
        }

        try
        {
            IsGeneratingFiles = true;
            SetMessage("Generating files...", autoClear: false);
            var packingStatus = DeadPackerService.GetStatus();
            if (packingStatus.Enabled && !packingStatus.GameRootValid)
            {
                ShowGameRootModal = true;
                GameRootPathInput = packingStatus.GameRootPath;
                GameRootMissingItems = packingStatus.GameRootMissingItems;
            }

            await InvokeAsync(StateHasChanged);
            await Task.Run(() => RoomService.GenerateZip(Code, PlayerId ?? string.Empty));
            CurrentRoom = RoomService.GetRoom(Code);
            SetMessage(string.IsNullOrWhiteSpace(CurrentRoom?.PackingError)
                ? "Generated files are ready."
                : "Raw ZIP generated. VPK generation failed; see details below.");
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message);
        }
        finally
        {
            IsGeneratingFiles = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SaveGameRootPath()
    {
        try
        {
            var status = DeadPackerService.SaveGameRootPath(GameRootPathInput);
            GameRootMissingItems = status.GameRootMissingItems;
            ShowGameRootModal = !status.GameRootValid;
            SetMessage(status.GameRootValid ? "Deadlock Reduced CSDK folder saved. You can generate files again." : "Deadlock Reduced CSDK folder is still invalid.");
        }
        catch (Exception ex)
        {
            var status = DeadPackerService.GetStatus();
            GameRootMissingItems = status.GameRootMissingItems;
            SetMessage(ex.Message);
        }
    }

