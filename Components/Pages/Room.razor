    private void SaveLobbySettings() => Try(() => RoomService.UpdateRoomConfig(Code, PlayerId ?? string.Empty, BuildLobbyConfig()));

    private async Task GenerateLobbyPreset()
    {
        if (!IsHost || LobbyDraftMode != DraftMode.Custom || CurrentRoom?.Status != DraftRoomStatus.Lobby)
        {
            return;
        }

        try
        {
            var json = CustomDraftPresetService.Export(BuildLobbyConfig());
            await JS.InvokeVoidAsync("deadlockAbilityDraft.downloadTextFile", "custom-draft-preset.json", json, "application/json");
            SetPresetMessage("Preset generated.");
        }
        catch (Exception ex)
        {
            SetPresetMessage(ex.Message);
        }
    }

    private async Task LoadLobbyPreset(InputFileChangeEventArgs args)
    {
        if (!IsHost || CurrentRoom is null)
        {
            return;
        }

        if (CurrentRoom.Status != DraftRoomStatus.Lobby)
        {
            SetPresetMessage("Presets can only be loaded before the draft starts.");
            return;
        }

        try
        {
            await using var stream = args.File.OpenReadStream(128 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            var result = CustomDraftPresetService.Import(json, CurrentRoom.DeadlockData, CurrentRoom.Bans, TimingOptions.Value);
            RoomService.UpdateRoomConfig(Code, PlayerId ?? string.Empty, result.Config);
            CurrentRoom = RoomService.GetRoom(Code);
            SyncLobbyFields();
            SetPresetMessage(result.Warnings.Count == 0
                ? "Preset loaded."
                : $"Preset loaded. {string.Join(" ", result.Warnings)}");
        }
        catch (InvalidDataException ex)
        {
            SetPresetMessage(ex.Message);
        }
        catch (Exception ex)
        {
            SetPresetMessage(ex.Message);
        }
    }

    private DraftRoomConfig BuildLobbyConfig()
    {
        var config = new DraftRoomConfig
        {
            DraftMode = LobbyDraftMode,
            CustomBaseDraftMode = LobbyDraftMode == DraftMode.Custom ? LobbyCustomBaseDraftMode : DraftMode.FreePick,
            AllowDuplicateAbilities = LobbyDraftMode == DraftMode.Custom && LobbyAllowDuplicates,
            AllowEmptySlotsAsBots = LobbyAllowBots,
            AllowHostOverridePicks = LobbyDraftMode == DraftMode.Custom && LobbyAllowOverride,
            DisableChat = LobbyDisableChat,
            MaxPlayers = Math.Clamp(LobbyMaxPlayers, 1, MaxLobbyPlayers),
            HeroPoolSize = LobbyHeroPoolSize,
            AllowDuplicateHeroes = LobbyDraftMode == DraftMode.Custom && LobbyAllowDuplicateHeroes,
            FlexibleUltimateSlots = LobbyDraftMode == DraftMode.Custom && LobbyFlexibleUltimates,
            BlindDraft = LobbyDraftMode == DraftMode.Custom && LobbyBlindDraft,
            FullRandom = LobbyDraftMode == DraftMode.Custom && LobbyFullRandom,
            PreparationSeconds = LobbyPreparationSeconds,
            PickSeconds = LobbyPickSeconds,
            RequiredHeroCount = 1,
            RequiredAbilitySlots = 4,
            UltimatePicksPerPlayer = LobbyDraftMode == DraftMode.Custom && LobbyFlexibleUltimates ? 0 : 1,
            PickOrder = LobbyPickOrder,
            AutoPickBehavior = LobbyAutoPickBehavior,
            TeamBalance = LobbyTeamBalance
        };
        config.CustomBans.BannedHeroes.UnionWith(LobbyCustomBannedHeroes);
        config.CustomBans.UnbannedHeroes.UnionWith(LobbyCustomUnbannedHeroes);
        config.CustomBans.BannedAbilities.UnionWith(LobbyCustomBannedAbilities);
        config.CustomBans.UnbannedAbilities.UnionWith(LobbyCustomUnbannedAbilities);
        return config;
    }

    private void StartAbilityDrag(int slotNumber, int fromIndex)
    {
        DragSlotNumber = slotNumber;
        DragFromIndex = fromIndex;
    }

    private void EndAbilityDrag()
    {
        DragSlotNumber = null;
        DragFromIndex = null;
    }

    private void DropAbility(int slotNumber, int toIndex)
    {
        if (DragSlotNumber != slotNumber || DragFromIndex is null)
        {
            EndAbilityDrag();
            return;
        }

        var fromIndex = DragFromIndex.Value;
        EndAbilityDrag();
        if (fromIndex == toIndex)
        {
            return;
        }

        Try(() => RoomService.ReorderRegularAbility(Code, PlayerId ?? string.Empty, slotNumber, fromIndex, toIndex));
    }

