    private void ClampLobbyPlayerLimits()
    {
        LobbyHeroPoolSize = Math.Clamp(LobbyHeroPoolSize, 1, MaxLobbyHeroPool);
        LobbyMaxPlayers = Math.Clamp(LobbyMaxPlayers, 1, MaxLobbyPlayers);
