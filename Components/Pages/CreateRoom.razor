@page "/create"
@rendermode InteractiveServer
@using abilitydraft.Models
@using abilitydraft.Services
@using Microsoft.Extensions.Options
@inject DraftRoomService RoomService
@inject ServerDeadlockDataService DataService
@inject NavigationManager Nav
@inject IOptions<DraftTimingOptions> TimingOptions
@inject IJSRuntime JS

<PageTitle>Create Draft Room</PageTitle>

<main class="page-shell">
    <section class="page-header">
        <a href="/">Back</a>
        <p class="eyebrow">Create room</p>
        <h1>Create Ability Draft</h1>
        <p>Host a Deadlock draft room, invite players by code, and let the server build the pool from its configured game data.</p>
    </section>

    <section class="form-panel create-panel">
        <div class="server-status @(Snapshot.IsLoaded ? "ok" : "bad")">
            <strong>@(Snapshot.IsLoaded ? "Server data ready" : "Server data missing")</strong>
            <span>@(Snapshot.Data?.Heroes.Count ?? 0) heroes - @(Snapshot.Data?.Abilities.Count ?? 0) abilities - @Snapshot.Bans.BannedHeroes.Count banned heroes - @BannedAbilityCount banned abilities</span>
        </div>
        @if (Snapshot.Errors.Count > 0)
        {
            <div class="warnings compact">
                @foreach (var error in Snapshot.Errors)
                {
                    <p>@error</p>
                }
            </div>
        }

        <label>
            <span>Room name</span>
            <input @bind="RoomName" />
        </label>
        <label>
            <span>Your name</span>
            <input @bind="HostName" />
        </label>
        <label>
            <span>Your team</span>
            <select @bind="SelectedTeam">
                <option value="@DeadlockTeam.HiddenKing">The Hidden King</option>
                <option value="@DeadlockTeam.Archmother">The Archmother</option>
            </select>
        </label>
        <label>
            <span>Draft mode</span>
            <select @bind="SelectedDraftMode">
                <option value="@DraftMode.FreePick">FreePick: heroes, abilities, and ultimates in any order</option>
                <option value="@DraftMode.Classic">Classic: heroes first, then abilities</option>
                <option value="@DraftMode.RandomHero">Random Hero: heroes assigned, abilities drafted</option>
                <option value="@DraftMode.Custom">Custom: advanced room-specific rules</option>
            </select>
        </label>
        @if (SelectedDraftMode == DraftMode.Custom)
        {
            @CustomSettingsPanel()
        }
        <label class="toggle">
            <input type="checkbox" @bind="DisableChat" />
            <span>Disable chat</span>
        </label>
        <label class="toggle">
            <input type="checkbox" @bind="AllowBots" />
            <span>Allow empty slots as bots</span>
        </label>
        <button class="primary" disabled="@(!Snapshot.IsLoaded)" @onclick="Create">Create room</button>
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <p class="message">@Message</p>
        }
    </section>
    <SiteFooter />
</main>

@code {
    private string RoomName = "Deadlock Ability Draft";
    private string HostName = string.Empty;
    private DeadlockTeam SelectedTeam = DeadlockTeam.HiddenKing;
    private DraftMode SelectedDraftMode = DraftMode.FreePick;
    private bool AllowBots;
    private bool AllowHostOverride;
    private bool DisableChat;
    private int CustomHeroPoolSize = 12;
    private int CustomMaxPlayers = 12;
    private bool CustomAllowDuplicateHeroes;
    private bool CustomAllowDuplicateAbilities;
    private bool CustomFlexibleUltimates;
    private bool CustomBlindDraft;
    private bool CustomFullRandom;
    private int CustomPreparationSeconds;
    private int CustomPickSeconds;
    private DraftMode CustomBaseDraftMode = DraftMode.FreePick;
    private DraftPickOrder CustomPickOrder = DraftPickOrder.AlternatingTeamsSnake;
    private DraftAutoPickBehavior CustomAutoPickBehavior = DraftAutoPickBehavior.RandomValidPick;
    private DraftTeamBalance CustomTeamBalance = DraftTeamBalance.AllowUnevenTeams;
    private string CustomBanSearch = string.Empty;
    private readonly HashSet<string> CustomBannedHeroes = new(StringComparer.Ordinal);
    private readonly HashSet<string> CustomUnbannedHeroes = new(StringComparer.Ordinal);
    private readonly HashSet<string> CustomBannedAbilities = new(StringComparer.Ordinal);
    private readonly HashSet<string> CustomUnbannedAbilities = new(StringComparer.Ordinal);
    private string Message = string.Empty;
    private string PresetMessage = string.Empty;
    private int PresetMessageVersion;
    private static readonly TimeSpan PresetMessageDuration = TimeSpan.FromSeconds(30);
    private DeadlockDataSnapshot Snapshot => DataService.Current;
    private int BannedAbilityCount => Snapshot.Data is null
        ? Snapshot.Bans.BannedAbilities.Count
        : Snapshot.Bans.BannedAbilities
            .Concat(Snapshot.Data.Abilities
                .Where(ability => ability.PickKind is DraftPickKind.RegularAbility or DraftPickKind.UltimateAbility)
                .Where(ability => DraftPoolGenerator.IsAbilityAutoBanned(ability, Snapshot.Data))
                .Select(ability => ability.Key))
            .Distinct(StringComparer.Ordinal)
            .Count();
    private int MaxCustomHeroPool => Math.Max(1, Snapshot.Data?.Heroes.Count ?? 12);
    private int MaxCustomPlayers => Math.Max(1, CustomHeroPoolSize);
    private int DefaultPreparationSeconds => PositiveOrDefault(TimingOptions.Value.PreparationSeconds, 30);
    private int DefaultPickSeconds => PositiveOrDefault(TimingOptions.Value.PickSeconds, 10);
    private int EffectivePreparationSeconds => PositiveOrDefault(CustomPreparationSeconds, DefaultPreparationSeconds);
    private int EffectivePickSeconds => PositiveOrDefault(CustomPickSeconds, DefaultPickSeconds);

    private void Create()
    {
        try
        {
            var result = RoomService.CreateRoom(RoomName, HostName, SelectedTeam, BuildDraftConfig());
            Nav.NavigateTo($"/room/{result.RoomCode}/lobby?playerId={result.PlayerId}");
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    private DraftRoomConfig BuildDraftConfig()
    {
        var config = new DraftRoomConfig
        {
            DraftMode = SelectedDraftMode,
            CustomBaseDraftMode = SelectedDraftMode == DraftMode.Custom ? CustomBaseDraftMode : DraftMode.FreePick,
            AllowEmptySlotsAsBots = AllowBots,
            AllowHostOverridePicks = SelectedDraftMode == DraftMode.Custom && AllowHostOverride,
            DisableChat = DisableChat,
            MaxPlayers = Math.Clamp(CustomMaxPlayers, 1, MaxCustomPlayers),
            HeroPoolSize = CustomHeroPoolSize,
            AllowDuplicateHeroes = SelectedDraftMode == DraftMode.Custom && CustomAllowDuplicateHeroes,
            AllowDuplicateAbilities = SelectedDraftMode == DraftMode.Custom && CustomAllowDuplicateAbilities,
            FlexibleUltimateSlots = SelectedDraftMode == DraftMode.Custom && CustomFlexibleUltimates,
            BlindDraft = SelectedDraftMode == DraftMode.Custom && CustomBlindDraft,
            FullRandom = SelectedDraftMode == DraftMode.Custom && CustomFullRandom,
            PreparationSeconds = SelectedDraftMode == DraftMode.Custom ? EffectivePreparationSeconds : 0,
            PickSeconds = SelectedDraftMode == DraftMode.Custom ? EffectivePickSeconds : 0,
            RequiredHeroCount = 1,
            RequiredAbilitySlots = 4,
            UltimatePicksPerPlayer = SelectedDraftMode == DraftMode.Custom && CustomFlexibleUltimates ? 0 : 1,
            PickOrder = CustomPickOrder,
            AutoPickBehavior = CustomAutoPickBehavior,
            TeamBalance = CustomTeamBalance
        };
        config.CustomBans.BannedHeroes.UnionWith(CustomBannedHeroes);
        config.CustomBans.UnbannedHeroes.UnionWith(CustomUnbannedHeroes);
        config.CustomBans.BannedAbilities.UnionWith(CustomBannedAbilities);
        config.CustomBans.UnbannedAbilities.UnionWith(CustomUnbannedAbilities);
        return config;
    }

    protected override void OnInitialized()
    {
        CustomPreparationSeconds = DefaultPreparationSeconds;
        CustomPickSeconds = DefaultPickSeconds;
    }

    private RenderFragment CustomSettingsPanel() => @<section class="custom-settings-panel">
            <div class="custom-settings-header">
                <div>
                    <strong>Custom draft rules</strong>
                    <span>These settings apply only to this room.</span>
                </div>
                <div class="preset-actions">
                    <button type="button" @onclick="GeneratePreset">Generate preset</button>
                    <label class="preset-upload">
                        Load preset
                        <InputFile OnChange="LoadPreset" accept="application/json,.json" />
                    </label>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(PresetMessage))
            {
                <p class="inline-message">@PresetMessage</p>
            }

            <div class="custom-settings-grid">
                <label>
                    <span>Base draft type</span>
                    <select @bind="CustomBaseDraftMode">
                        <option value="@DraftMode.FreePick">Free Pick</option>
                        <option value="@DraftMode.Classic">Classic</option>
                        <option value="@DraftMode.RandomHero">Random Hero</option>
                    </select>
                </label>
                <label>
                    <span>Hero pool size</span>
                    <input type="number" min="1" max="@MaxCustomHeroPool" @bind="CustomHeroPoolSize" @bind:after="ClampCustomPlayerLimits" />
                </label>
                <label>
                    <span>Max players in lobby</span>
                    <input type="number" min="1" max="@MaxCustomPlayers" @bind="CustomMaxPlayers" @bind:after="ClampCustomPlayerLimits" />
                </label>
                <label>
                    <span>Pick order</span>
                    <select @bind="CustomPickOrder">
                        <option value="@DraftPickOrder.AlternatingTeamsSnake">Alternating teams snake order</option>
                        <option value="@DraftPickOrder.AlternatingTeamsForward">Alternating teams forward order</option>
                        <option value="@DraftPickOrder.RandomPlayerEachRound">Random player order each round</option>
                    </select>
                </label>
                <label>
                    <span>Auto-pick behavior</span>
                    <select @bind="CustomAutoPickBehavior">
                        <option value="@DraftAutoPickBehavior.RandomValidPick">Random valid pick</option>
                        <option value="@DraftAutoPickBehavior.SkipPick">Skip pick</option>
                        <option value="@DraftAutoPickBehavior.SameSourceHeroIfPossible">Pick from same source hero if possible</option>
                    </select>
                </label>
                <label>
                    <span>Team balance</span>
                    <select @bind="CustomTeamBalance">
                        <option value="@DraftTeamBalance.AllowUnevenTeams">Allow uneven teams</option>
                        <option value="@DraftTeamBalance.RequireEqualTeams">Require equal teams</option>
                        <option value="@DraftTeamBalance.AutoBalanceOnStart">Auto-balance teams on draft start</option>
                    </select>
                </label>
                <label>
                    <span>Preparation time</span>
                    <input type="number" min="1" @bind="CustomPreparationSeconds" placeholder="@DefaultPreparationSeconds" />
                </label>
                <label>
                    <span>Pick timer</span>
                    <input type="number" min="1" @bind="CustomPickSeconds" placeholder="@DefaultPickSeconds" />
                </label>
            </div>

            <div class="custom-toggle-grid">
                <label class="toggle"><input type="checkbox" @bind="CustomAllowDuplicateHeroes" /><span>Allow duplicate heroes</span></label>
                <label class="toggle"><input type="checkbox" @bind="CustomAllowDuplicateAbilities" /><span>Allow duplicate abilities</span></label>
                <label class="toggle"><input type="checkbox" @bind="CustomFlexibleUltimates" /><span>Flexible ultimate slots</span></label>
                <label class="toggle"><input type="checkbox" @bind="CustomBlindDraft" /><span>Blind draft</span></label>
                <label class="toggle"><input type="checkbox" @bind="CustomFullRandom" /><span>Full Random</span></label>
                <label class="toggle"><input type="checkbox" @bind="AllowHostOverride" /><span>Allow host override picks/reorder for human slots</span></label>
            </div>

            <details class="custom-ban-panel">
                <summary>Custom bans</summary>
                <input class="custom-search" placeholder="Search heroes or abilities" @bind="CustomBanSearch" @bind:event="oninput" />
                <div class="custom-ban-columns">
                    <div>
                        <h4>Heroes</h4>
                        @foreach (var hero in FilteredHeroes())
                        {
                            var defaultBanned = Snapshot.Bans.BannedHeroes.Contains(hero.Key);
                            <label class="custom-ban-row">
                                @HeroIcon(hero)
                                <span>
                                    <strong>@hero.DisplayName</strong>
                                    <small>@hero.Key</small>
                                    @if (defaultBanned)
                                    {
                                        <em>Banned by default</em>
                                    }
                                </span>
                                <label><input type="checkbox" checked="@CustomBannedHeroes.Contains(hero.Key)" @onchange="args => ToggleSet(CustomBannedHeroes, hero.Key, args)" /> Ban</label>
                                <label><input type="checkbox" checked="@CustomUnbannedHeroes.Contains(hero.Key)" @onchange="args => ToggleSet(CustomUnbannedHeroes, hero.Key, args)" /> Unban</label>
                            </label>
                        }
                    </div>
                    <div>
                        <h4>Abilities</h4>
                        @foreach (var ability in FilteredAbilities())
                        {
                            var autoBanned = Snapshot.Data is not null && DraftPoolGenerator.IsAbilityAutoBanned(ability, Snapshot.Data);
                            var defaultBanned = Snapshot.Data is not null && DraftPoolGenerator.IsAbilityBanned(ability, Snapshot.Bans, Snapshot.Data);
                            <div class="custom-ban-row ability-ban-row">
                                @AbilityIcon(ability)
                                <span>
                                    <strong>@ability.DisplayName</strong>
                                    <small>@ability.Key - @ability.SourceHeroName</small>
                                    @if (autoBanned)
                                    {
                                        <em>Unknown source</em>
                                    }
                                    else if (defaultBanned)
                                    {
                                        <em>Banned by default</em>
                                    }
                                </span>
                                <label><input type="checkbox" checked="@CustomBannedAbilities.Contains(ability.Key)" @onchange="args => ToggleSet(CustomBannedAbilities, ability.Key, args)" /> Ban</label>
                                <label><input type="checkbox" disabled="@autoBanned" checked="@CustomUnbannedAbilities.Contains(ability.Key)" @onchange="args => ToggleSet(CustomUnbannedAbilities, ability.Key, args)" /> Unban</label>
                            </div>
                        }
                    </div>
                </div>
            </details>
    </section>;

    private IEnumerable<HeroDefinition> FilteredHeroes()
    {
        var heroes = Snapshot.Data?.Heroes ?? [];
        return heroes
            .Where(hero => MatchesSearch(hero.DisplayName, hero.Key))
            .OrderBy(hero => hero.DisplayName);
    }

    private IEnumerable<AbilityDefinition> FilteredAbilities()
    {
        var abilities = Snapshot.Data?.Abilities ?? [];
        return abilities
            .Where(ability => ability.PickKind is DraftPickKind.RegularAbility or DraftPickKind.UltimateAbility)
            .Where(ability => Snapshot.Data is null || !DraftPoolGenerator.IsAbilityAutoBanned(ability, Snapshot.Data))
            .Where(ability => MatchesSearch(ability.DisplayName, ability.Key, ability.SourceHeroName))
            .OrderBy(ability => ability.DisplayName);
    }

    private bool MatchesSearch(params string[] values)
    {
        if (string.IsNullOrWhiteSpace(CustomBanSearch))
        {
            return true;
        }

        return values.Any(value => value.Contains(CustomBanSearch, StringComparison.OrdinalIgnoreCase));
    }

    private static void ToggleSet(HashSet<string> set, string key, ChangeEventArgs args)
    {
        if (args.Value is bool enabled && enabled)
        {
            set.Add(key);
        }
        else
        {
            set.Remove(key);
        }
    }

    private async Task GeneratePreset()
    {
        try
        {
            var json = CustomDraftPresetService.Export(BuildDraftConfig());
            await JS.InvokeVoidAsync("deadlockAbilityDraft.downloadTextFile", "custom-draft-preset.json", json, "application/json");
            SetPresetMessage("Preset generated.");
        }
        catch (Exception ex)
        {
            SetPresetMessage(ex.Message);
        }
    }

    private async Task LoadPreset(InputFileChangeEventArgs args)
    {
        if (Snapshot.Data is null)
        {
            SetPresetMessage("Server data is not loaded.");
            return;
        }

        try
        {
            await using var stream = args.File.OpenReadStream(128 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            var result = CustomDraftPresetService.Import(json, Snapshot.Data, Snapshot.Bans, TimingOptions.Value);
            ApplyPresetConfig(result.Config);
            SetPresetMessage(result.Warnings.Count == 0
                ? "Preset loaded."
                : $"Preset loaded. {string.Join(" ", result.Warnings)}");
        }
        catch (InvalidDataException ex)
        {
            SetPresetMessage(ex.Message);
        }
        catch (Exception ex)
        {
            SetPresetMessage(ex.Message);
        }
    }

    private void SetPresetMessage(string value)
    {
        PresetMessage = value;
        _ = ClearPresetMessageAfterDelay(++PresetMessageVersion);
    }

    private async Task ClearPresetMessageAfterDelay(int version)
    {
        try
        {
            await Task.Delay(PresetMessageDuration);
            if (version != PresetMessageVersion)
            {
                return;
            }

            PresetMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private void ApplyPresetConfig(DraftRoomConfig config)
    {
        SelectedDraftMode = DraftMode.Custom;
        CustomBaseDraftMode = config.CustomBaseDraftMode;
        CustomHeroPoolSize = config.HeroPoolSize;
        CustomMaxPlayers = config.MaxPlayers;
        CustomPickOrder = config.PickOrder;
        CustomAutoPickBehavior = config.AutoPickBehavior;
        CustomTeamBalance = config.TeamBalance;
        CustomPreparationSeconds = config.PreparationSeconds;
        CustomPickSeconds = config.PickSeconds;
        CustomAllowDuplicateHeroes = config.AllowDuplicateHeroes;
        CustomAllowDuplicateAbilities = config.AllowDuplicateAbilities;
        CustomFlexibleUltimates = config.FlexibleUltimateSlots;
        CustomBlindDraft = config.BlindDraft;
        CustomFullRandom = config.FullRandom;
        AllowHostOverride = config.AllowHostOverridePicks;
        DisableChat = config.DisableChat;
        AllowBots = config.AllowEmptySlotsAsBots;
        CustomBannedHeroes.Clear();
        CustomUnbannedHeroes.Clear();
        CustomBannedAbilities.Clear();
        CustomUnbannedAbilities.Clear();
        CustomBannedHeroes.UnionWith(config.CustomBans.BannedHeroes);
        CustomUnbannedHeroes.UnionWith(config.CustomBans.UnbannedHeroes);
        CustomBannedAbilities.UnionWith(config.CustomBans.BannedAbilities);
        CustomUnbannedAbilities.UnionWith(config.CustomBans.UnbannedAbilities);
        ClampCustomPlayerLimits();
    }

    private void ClampCustomPlayerLimits()
    {
        CustomHeroPoolSize = Math.Clamp(CustomHeroPoolSize, 1, MaxCustomHeroPool);
        CustomMaxPlayers = Math.Clamp(CustomMaxPlayers, 1, MaxCustomPlayers);
    }

    private static int PositiveOrDefault(params int[] values)
    {
        foreach (var value in values)
        {
            if (value > 0)
            {
                return value;
            }
        }

        return 1;
    }

    private RenderFragment HeroIcon(HeroDefinition hero) => builder =>
    {
        if (!string.IsNullOrWhiteSpace(hero.IconDataUrl))
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "src", hero.IconDataUrl);
            builder.AddAttribute(2, "alt", hero.DisplayName);
            builder.CloseElement();
        }
    };

    private RenderFragment AbilityIcon(AbilityDefinition ability) => builder =>
    {
        if (!string.IsNullOrWhiteSpace(ability.IconDataUrl))
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "src", ability.IconDataUrl);
            builder.AddAttribute(2, "alt", ability.DisplayName);
            builder.CloseElement();
        }
    };
}
