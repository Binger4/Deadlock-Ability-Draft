@page "/"

<PageTitle>Deadlock Ability Draft</PageTitle>

<main class="home-shell">
    <section class="hero-band">
        <div class="hero-copy">
            <p class="eyebrow">Deadlock mod builder</p>
            <h1>Ability Draft for Deadlock</h1>
            <p>Create a room from server-side Deadlock files, invite players by code, choose a team, draft through a timed snake order, then export modified heroes, abilities, and optional VPK files.</p>
            <div class="home-actions">
                <a class="primary-link" href="/create">Create room</a>
                <a class="secondary-link" href="/join">Join room</a>
            </div>
        </div>
        <div class="home-status-grid" aria-label="Draft flow">
            <span>12 hero pool</span>
            <span>Timed picks</span>
            <span>Team snake order</span>
            <span>ZIP + VPK export</span>
        </div>
    </section>
    <SiteFooter />
</main>
