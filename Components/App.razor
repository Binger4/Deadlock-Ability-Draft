@inject NavigationManager Nav

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["abilitydraft.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <meta property="og:title" content="Deadlock Ability Draft" />
    <meta property="og:description" content="Create Deadlock draft rooms, draft heroes and abilities with friends, and export VPK files for custom Deadlock games." />
    <meta property="og:image" content="@PreviewImageUrl" />
    <meta property="og:url" content="@SiteUrl" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Deadlock Ability Draft" />
    <meta name="twitter:description" content="Create Deadlock draft rooms, draft heroes and abilities with friends, and export VPK files for custom Deadlock games." />
    <meta name="twitter:image" content="@PreviewImageUrl" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["draft-sounds.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    private string SiteUrl => Nav.BaseUri.TrimEnd('/');
    private string PreviewImageUrl => new Uri(new Uri(Nav.BaseUri), "site-preview.png").AbsoluteUri;
}
